# Required for Alpaca premium news and bars.
ALPACA_API_KEY_ID=
ALPACA_API_SECRET_KEY=
ALPACA_STOCK_FEED=sip
ALPACA_TRADING_BASE_URL=https://api.alpaca.markets

# Non-secret runtime config.
APP_CONFIG_PATH=configs/default.toml

# SEC requires a descriptive user agent with contact info.
SEC_USER_AGENT=market-predictor/0.1 your-email@example.com

# Required for durable Reddit API crawling.
# Create a Reddit "script" app and use its client id/secret.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=
REDDIT_USER_AGENT=market-predictor/0.1 by your_reddit_username

# Required for Seeking Alpha via RapidAPI.
# Subscribe to the Seeking Alpha API on RapidAPI and paste the app key here.
RAPIDAPI_KEY=

# Optional Seeking Alpha account token via RapidAPI.
# Do not commit real values. Only needed for endpoints that require an SA account token.
SEEKING_ALPHA_ACCOUNT_EMAIL=
SEEKING_ALPHA_ACCOUNT_PASSWORD=
SEEKING_ALPHA_ACCESS_TOKEN_CACHE_FILE=data/cache/seeking_alpha/access_token.json

# Optional model override. Default is ProsusAI/finbert.
FINBERT_MODEL=ProsusAI/finbert

# Azure artifact storage for market-predictor.
# Prefer managed identity in Azure. Locally, either set AZURE_STORAGE_CONNECTION_STRING
# or AZURE_STORAGE_ACCOUNT_URL plus Azure CLI login/default credentials.
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_ACCOUNT_URL=
AZURE_STORAGE_CONTAINER=market-data
AZURE_BLOB_PREFIX=market-predictor

# API process guardrails. Container Apps must also enforce a 4 GiB memory limit.
RUNTIME_MEMORY_BUDGET_GIB=4.0
RUNTIME_MEMORY_HEADROOM_GIB=0.25

# Production API authentication. Refresh the public JWKS file out of band and mount it
# read-only. API_ENVIRONMENT=production rejects development/static auth.
API_ENVIRONMENT=production
API_AUTH_MODE=entra
API_JWT_ISSUER=https://login.microsoftonline.com/<tenant-id>/v2.0
API_JWT_AUDIENCE=<market-predictor-api-client-id>
API_JWKS_PATH=/app/config/entra-jwks.json

# Development only. Use at least 32 random characters and never commit the value.
# API_ENVIRONMENT=development
# API_AUTH_MODE=development
# API_DEVELOPMENT_BEARER_TOKEN=

API_MAXIMUM_BODY_BYTES=65536
API_MAXIMUM_RATE_LIMIT_PRINCIPALS=10000
API_PREDICTION_REQUESTS_PER_MINUTE=60
API_OPERATIONS_REQUESTS_PER_MINUTE=30
API_METRICS_REQUESTS_PER_MINUTE=30
API_REPLAY_REQUESTS_PER_MINUTE=5
API_REPLAY_ENABLED=false
